# HireHub — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs.
# Ne commitez JAMAIS le fichier .env (il est dans .gitignore).

# Base de données PostgreSQL
DB_USERNAME=hirehub
DB_PASSWORD=hirehub

# RabbitMQ
RABBITMQ_USERNAME=hirehub
RABBITMQ_PASSWORD=hirehub

# JWT (secret >= 32 caractères)
HIREHUB_JWT_SECRET=hirehub-local-dev-jwt-secret-change-me-32b

# Email / SMTP — mailpit par défaut (dev), remplacez pour la production
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@hirehub.com

# Google OAuth2 (optionnel — laisser vide pour désactiver)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OCR Space — vérification documents recruteurs
OCR_SPACE_API_KEY=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=hirehub
