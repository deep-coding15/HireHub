{
  "title": "HireHub — Resilience4j Circuit Breakers",
  "uid": "hirehub-resilience4j",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["hirehub", "resilience4j"],
  "panels": [
    {
      "id": 1,
      "title": "États des Circuit Breakers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" }, "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{application=~\".+\"}",
          "legendFormat": "{{name}} ({{application}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "Taux d'échec des Circuit Breakers (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_failure_rate{application=~\".+\"}",
          "legendFormat": "{{name}} ({{application}})"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taux d'appels lents (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_slow_call_rate{application=~\".+\"}",
          "legendFormat": "{{name}} ({{application}})"
        }
      ]
    },
    {
      "id": 4,
      "title": "Appels par résultat — candidature-service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "successful" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "not_permitted" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{application=\"candidature-service\"}[1m])",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Appels par résultat — email-service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "successful" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{application=\"email-service\"}[1m])",
          "legendFormat": "{{kind}} — {{name}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Retry — Appels réussis sans retry vs échoués après retry",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "rate(resilience4j_retry_calls_total{kind=\"successful_without_retry\"}[1m])",
          "legendFormat": "succès sans retry — {{name}} ({{application}})"
        },
        {
          "expr": "rate(resilience4j_retry_calls_total{kind=\"failed_with_retry\"}[1m])",
          "legendFormat": "échec après retry — {{name}} ({{application}})"
        }
      ]
    }
  ]
}
